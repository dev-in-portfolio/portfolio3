    <span class="badge">{{ collections.tagList | length }} tags</span>
    <span class="badge">{{ collections.kindList | length }} kinds</span>
  </div>
</section>

<div class="search-box">
  <input id="search-input" type="text" placeholder="Search targets" />
</div>
<div id="search-results"></div>

